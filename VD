local function UpdateESP()
    -- HANYA RUN LOOP JIKA SALAH SATU ESP PLAYER/KILLER AKTIF
    if isPlayerEspActive or isKillerEspActive then
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                local isKiller = isPlayerKiller(p)
                local root = p.Character:FindFirstChild("HumanoidRootPart")
                if root then
                    -- Hindari menghitung jarak jika target ESP nya tidak diaktifkan
                    if (not isKiller and isPlayerEspActive) or (isKiller and isKillerEspActive) then
                        local distance = math.floor((Camera.CFrame.Position - root.Position).Magnitude)
                        local espText = p.Name .. "\n[" .. distance .. "m]"
                        
                        if not isKiller and isPlayerEspActive then
                            if not p.Character:FindFirstChild("PEH") then local h = Instance.new("Highlight", p.Character); h.Name = "PEH"; h.FillColor = PlayerEspColor; h.FillTransparency = 0.5 end
                            CreateOrUpdateEspText(p.Character, "PE_Text", PlayerEspColor, espText)
                        end
                        if isKiller and isKillerEspActive then
                            if not p.Character:FindFirstChild("KEH") then local h = Instance.new("Highlight", p.Character); h.Name = "KEH"; h.FillColor = KillerEspColor; h.FillTransparency = 0.5 end
                            CreateOrUpdateEspText(p.Character, "KE_Text", KillerEspColor, espText)
                        end
                    end
                end
            end
        end
    end
    
    -- HANYA RUN LOOP JIKA ESP GENERATOR AKTIF
    if isGeneratorEspActive then
        for _, v in pairs(activeGenerators) do
            if v and v.Parent then
                if not v:FindFirstChild("GEH") then local h = Instance.new("Highlight", v); h.Name = "GEH"; h.FillColor = GeneratorEspColor; h.FillTransparency = 0.5 end
            end
        end
    end

    -- HANYA RUN LOOP JIKA ESP PALLET AKTIF
    if isPalletEspActive then
        for _, v in pairs(activePallets) do
            if v and v.Parent then
                if not v:FindFirstChild("PalletEH") then local h = Instance.new("Highlight", v); h.Name = "PalletEH"; h.FillColor = PalletEspColor; h.FillTransparency = 0.5 end
            end
        end
    end

    -- HANYA RUN LOOP JIKA ESP HOOK AKTIF
    if isHookEspActive then
        for i, v in ipairs(activeHooks) do
            if v and v.Parent then
                if not v:FindFirstChild("HookEH") then local h = Instance.new("Highlight", v); h.Name = "HookEH"; h.FillColor = HookEspColor; h.FillTransparency = 0.5 end
                local hookPoint = v:FindFirstChild("HookPoint"); local targetPos = hookPoint and hookPoint.Position or v:GetPivot().Position
                local distance = math.floor((Camera.CFrame.Position - targetPos).Magnitude)
                CreateOrUpdateEspText(v, "HookE_Text", HookEspColor, "[" .. i .. "]")
            end
        end
    end
end

