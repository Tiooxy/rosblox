local function CreateDropdown(parent, placeholder, order, options_func, callback)
    local Container = Instance.new("Frame", parent); Container.Size = UDim2.new(1, -25, 0, 45); Container.BackgroundTransparency = 1; Container.LayoutOrder = order
    local MainBtn = Instance.new("TextButton", Container); MainBtn.Size = UDim2.new(1, 0, 0, 45); MainBtn.BackgroundColor3 = PanelColor; MainBtn.Text = placeholder; MainBtn.TextColor3 = Color3.new(1,1,1); MainBtn.TextSize = 24; MainBtn.Font = "PatrickHand"
    Instance.new("UICorner", MainBtn).CornerRadius = UDim.new(0, 10)
    addRainbow(Instance.new("UIStroke", MainBtn), "Color")
    ApplyButtonInteraction(MainBtn)

    local List = Instance.new("ScrollingFrame", MainBtn)
    List.Size = UDim2.new(1, 0, 0, 0); List.Position = UDim2.new(0, 0, 1, 5); List.BackgroundColor3 = PanelColor; List.Visible = false; List.ZIndex = 500; List.ScrollBarThickness = 4; List.Active = true; List.Selectable = true; List.ScrollingDirection = Enum.ScrollingDirection.Y; List.ClipsDescendants = true
    Instance.new("UICorner", List).CornerRadius = UDim.new(0, 10); Instance.new("UIListLayout", List)

    local function Toggle()
        if List.Visible then
            TweenService:Create(List, TweenInfo.new(0.3), {Size = UDim2.new(1,0,0,0)}):Play()
            TweenService:Create(Container, TweenInfo.new(0.3), {Size = UDim2.new(1,-25,0,45)}):Play()
            task.delay(0.3, function() List.Visible = false end); activeDropdownClose = nil
        else
            if activeDropdownClose then activeDropdownClose() end
            List.Visible = true; local opts = options_func()
            for _,v in pairs(List:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
            for _, opt in pairs(opts) do
                local b = Instance.new("TextButton", List); b.Size = UDim2.new(1, 0, 0, 40); b.Text = tostring(opt); b.TextColor3 = Color3.new(1,1,1); b.TextSize = 22; b.Font = "PatrickHand"; b.BackgroundTransparency = 1
                b.MouseButton1Click:Connect(function() MainBtn.Text = tostring(opt); Toggle(); callback(opt) end)
                ApplyButtonInteraction(b)
            end
            local targetH = math.min(#opts * 40, 120); List.CanvasSize = UDim2.new(0,0,0, #opts * 40)
            TweenService:Create(List, TweenInfo.new(0.3), {Size = UDim2.new(1,0,0,targetH)}):Play()
            TweenService:Create(Container, TweenInfo.new(0.3), {Size = UDim2.new(1,-25,0,45 + targetH + 5)}):Play()
            activeDropdownClose = Toggle
        end
    end
    MainBtn.MouseButton1Click:Connect(Toggle)
    return Container, MainBtn
end

-- SISTEM SLIDER
local function CreateSlider(parent, titleText, minVal, maxVal, defaultVal, layoutOrder, callback)
    local Container = Instance.new("Frame", parent)
    Container.Size = UDim2.new(1, -20, 0, 65); Container.BackgroundTransparency = 1; Container.LayoutOrder = layoutOrder

    local Title = Instance.new("TextLabel", Container)
    Title.Size = UDim2.new(1, -50, 0, 25); Title.Position = UDim2.new(0,0,0,0)
    Title.Text = titleText:upper(); Title.TextColor3 = Color3.new(1,1,1); Title.TextSize = 24; Title.Font = "PatrickHand"; Title.BackgroundTransparency = 1; Title.TextXAlignment = Enum.TextXAlignment.Left

    local ValText = Instance.new("TextLabel", Container)
    ValText.Size = UDim2.new(0, 50, 0, 25); ValText.Position = UDim2.new(1, -50, 0, 0)
    ValText.Text = tostring(defaultVal); ValText.TextColor3 = Color3.new(1,1,1); ValText.TextSize = 24; ValText.Font = "PatrickHand"; ValText.BackgroundTransparency = 1; ValText.TextXAlignment = Enum.TextXAlignment.Right

    local Track = Instance.new("TextButton", Container)
    Track.Size = UDim2.new(1, 0, 0, 15); Track.Position = UDim2.new(0, 0, 0, 35); Track.BackgroundColor3 = PanelColor; Track.Text = ""; Track.AutoButtonColor = false
    Instance.new("UICorner", Track).CornerRadius = UDim.new(1, 0)
    ApplyButtonInteraction(Track)

    local Fill = Instance.new("Frame", Track)
    Fill.Size = UDim2.new((defaultVal - minVal) / (maxVal - minVal), 0, 1, 0)
    Instance.new("UICorner", Fill).CornerRadius = UDim.new(1, 0)
    addRainbow(Fill, "BackgroundColor3")

    local function SetValue(val)
        val = math.clamp(val, minVal, maxVal)
        local pos = (val - minVal) / (maxVal - minVal)
        TweenService:Create(Fill, TweenInfo.new(0.1), {Size = UDim2.new(pos, 0, 1, 0)}):Play()
        ValText.Text = tostring(val)
        callback(val)
    end

    local isDragging = false
    Track.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            isDragging = true
            local pos = math.clamp((input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
            local val = math.floor(minVal + (maxVal - minVal) * pos)
            SetValue(val)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then isDragging = false end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if isDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local pos = math.clamp((input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
            local val = math.floor(minVal + (maxVal - minVal) * pos)
            SetValue(val)
        end
    end)

    return Container, SetValue
end

