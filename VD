-- ================= SYSTEM AUTO TELEPORT GENERATOR =================
local function getBestGenerator()
    scanMapObjects() 
    local bestGen = nil
    for _, gen in pairs(activeGenerators) do
        if gen and gen.Parent then
            local playersNearby = 0
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    local dist = (p.Character.HumanoidRootPart.Position - gen:GetPivot().Position).Magnitude
                    if dist < 15 then 
                        playersNearby = playersNearby + 1
                    end
                end
            end
            if playersNearby == 0 then
                return gen 
            elseif bestGen == nil then
                bestGen = gen 
            end
        end
    end
    return bestGen
end

-- LOOP UTAMA UNTUK AUTO TELEPORT
task.spawn(function()
    while task.wait(0.5) do
        if isAutoGenActive and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local root = LocalPlayer.Character.HumanoidRootPart
            
            local killerTooClose = false
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and isPlayerKiller(p) and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    local dist = (p.Character.HumanoidRootPart.Position - root.Position).Magnitude
                    if dist <= 25 then 
                        killerTooClose = true
                        break
                    end
                end
            end

            if killerTooClose then
                currentAutoGenTarget = getBestGenerator()
                if currentAutoGenTarget then
                    LocalPlayer.Character:PivotTo(currentAutoGenTarget:GetPivot() * CFrame.new(0, 2, 8))
                    task.wait(1)
                end
                continue
            end

            if not currentAutoGenTarget or not currentAutoGenTarget.Parent then
                currentAutoGenTarget = getBestGenerator()
                if currentAutoGenTarget then
                    LocalPlayer.Character:PivotTo(currentAutoGenTarget:GetPivot() * CFrame.new(0, 2, 8))
                    task.wait(0.5)
                end
            else
                local distToGen = (root.Position - currentAutoGenTarget:GetPivot().Position).Magnitude
                if distToGen > 20 then
                    LocalPlayer.Character:PivotTo(currentAutoGenTarget:GetPivot() * CFrame.new(0, 2, 8))
                end
            end
        end
    end
end)

