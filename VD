-- SCAN MAP OBJECTS
local function scanMapObjects()
    table.clear(activeGenerators)
    table.clear(activePallets)
    table.clear(activeHooks)
    table.clear(activeGates)
    
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Model") or v:IsA("BasePart") then
            local name = string.lower(v.Name)
            if name == "generator" and v:IsA("Model") then
                table.insert(activeGenerators, v)
            elseif string.find(name, "pallet") then
                table.insert(activePallets, v)
            elseif name == "hook" and v:IsA("Model") and v:FindFirstChild("HookPoint") then
                table.insert(activeHooks, v)
            elseif name == "gate" and v:IsA("Model") then
                table.insert(activeGates, v)
            end
        end
    end
end

