local FlyBtn = CreateButton(MiscPage, "button fly: off", 5)
FlyBtn.MouseButton1Click:Connect(function()
    isFlying = not isFlying
    FlyBtn.Text = isFlying and "button fly: on" or "button fly: off"
    FlyBtn.TextColor3 = isFlying and Color3.new(0,1,0) or Color3.new(1,1,1)
    
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not char or not hum or not root then return end
    
    if isFlying then
        if char:FindFirstChild("Animate") then char.Animate.Disabled = true end
        for _, track in pairs(hum:GetPlayingAnimationTracks()) do track:Stop() end
        hum:ChangeState(Enum.HumanoidStateType.Swimming)
        
        local bv = Instance.new("BodyVelocity", root); bv.Name = "FlyStable"; bv.MaxForce = Vector3.new(1e6, 1e6, 1e6); bv.Velocity = Vector3.new(0, 0, 0)
        local bg = Instance.new("BodyGyro", root); bg.Name = "FlyGyro"; bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9); bg.P = 9e4; bg.CFrame = Camera.CFrame

        if flyConnection then flyConnection:Disconnect() end
        flyConnection = RunService.Heartbeat:Connect(function()
            if not char or not root or not hum then return end
            bg.CFrame = Camera.CFrame
            if hum.MoveDirection.Magnitude > 0 then
                local moveDir = hum.MoveDirection
                local camLook = Camera.CFrame.LookVector
                local yMove = 0
                if UserInputService:IsKeyDown(Enum.KeyCode.W) or moveDir:Dot(Camera.CFrame.LookVector) > 0.5 then yMove = camLook.Y
                elseif UserInputService:IsKeyDown(Enum.KeyCode.S) or moveDir:Dot(Camera.CFrame.LookVector) < -0.5 then yMove = -camLook.Y end
                char:TranslateBy(Vector3.new(moveDir.X, yMove, moveDir.Z) * (flySpeed / 10))
            end
        end)
    else
        if flyConnection then flyConnection:Disconnect() end
        if root:FindFirstChild("FlyStable") then root.FlyStable:Destroy() end
        if root:FindFirstChild("FlyGyro") then root.FlyGyro:Destroy() end 
        if char:FindFirstChild("Animate") then char.Animate.Disabled = false end
        hum:ChangeState(Enum.HumanoidStateType.Running)
    end
end)

