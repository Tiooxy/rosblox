local function CreateSearchableDropdown(parent, placeholder, order, optionsDict, callback)
    local Container = Instance.new("Frame", parent); Container.Size = UDim2.new(1, -25, 0, 45); Container.BackgroundTransparency = 1; Container.LayoutOrder = order
    local MainBtn = Instance.new("TextButton", Container); MainBtn.Size = UDim2.new(1, 0, 0, 45); MainBtn.BackgroundColor3 = PanelColor; MainBtn.Text = placeholder; MainBtn.TextColor3 = Color3.new(1,1,1); MainBtn.TextSize = 24; MainBtn.Font = "PatrickHand"
    Instance.new("UICorner", MainBtn).CornerRadius = UDim.new(0, 10)
    addRainbow(Instance.new("UIStroke", MainBtn), "Color")
    ApplyButtonInteraction(MainBtn)

    local DropMain = Instance.new("Frame", MainBtn)
    DropMain.Size = UDim2.new(1, 0, 0, 0); DropMain.Position = UDim2.new(0, 0, 1, 5)
    DropMain.BackgroundColor3 = PanelColor; DropMain.ClipsDescendants = true
    Instance.new("UICorner", DropMain).CornerRadius = UDim.new(0, 10)
    DropMain.Visible = false; DropMain.ZIndex = 500

    local SearchBox = Instance.new("TextBox", DropMain)
    SearchBox.Size = UDim2.new(1, -10, 0, 30); SearchBox.Position = UDim2.new(0, 5, 0, 5)
    SearchBox.BackgroundColor3 = BGColor; SearchBox.TextColor3 = Color3.new(1,1,1)
    SearchBox.PlaceholderText = "Search..."; SearchBox.Text = ""
    SearchBox.Font = "PatrickHand"; SearchBox.TextSize = 20
    Instance.new("UICorner", SearchBox).CornerRadius = UDim.new(0,5)

    local List = Instance.new("ScrollingFrame", DropMain)
    List.Size = UDim2.new(1, 0, 1, -40); List.Position = UDim2.new(0, 0, 0, 40)
    List.BackgroundTransparency = 1; List.ScrollBarThickness = 4
    Instance.new("UIListLayout", List)

    local names = {}
    local function UpdateNames()
        names = {}
        for k, _ in pairs(optionsDict) do table.insert(names, k) end
        table.sort(names)
    end
    UpdateNames()

    local function Populate(filterText)
        for _, v in pairs(List:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
        local count = 0
        for _, name in ipairs(names) do
            if filterText == "" or string.find(string.lower(name), string.lower(filterText)) then
                count = count + 1
                local b = Instance.new("TextButton", List); b.Size = UDim2.new(1, 0, 0, 35); b.Text = name; b.TextColor3 = Color3.new(1,1,1); b.TextSize = 20; b.Font = "PatrickHand"; b.BackgroundTransparency = 1
                b.MouseButton1Click:Connect(function()
                    MainBtn.Text = name
                    callback(optionsDict[name])
                    TweenService:Create(DropMain, TweenInfo.new(0.3), {Size = UDim2.new(1,0,0,0)}):Play()
                    TweenService:Create(Container, TweenInfo.new(0.3), {Size = UDim2.new(1,-25,0,45)}):Play()
                    task.delay(0.3, function() DropMain.Visible = false end)
                    activeDropdownClose = nil
                end)
                ApplyButtonInteraction(b)
            end
        end
        List.CanvasSize = UDim2.new(0, 0, 0, count * 35)
    end

    SearchBox.Changed:Connect(function(prop)
        if prop == "Text" then Populate(SearchBox.Text) end
    end)

    local function Toggle()
        if DropMain.Visible then
            TweenService:Create(DropMain, TweenInfo.new(0.3), {Size = UDim2.new(1,0,0,0)}):Play()
            TweenService:Create(Container, TweenInfo.new(0.3), {Size = UDim2.new(1,-25,0,45)}):Play()
            task.delay(0.3, function() DropMain.Visible = false end); activeDropdownClose = nil
        else
            if activeDropdownClose then activeDropdownClose() end
            DropMain.Visible = true; SearchBox.Text = ""; Populate("")
            TweenService:Create(DropMain, TweenInfo.new(0.3), {Size = UDim2.new(1,0,0,160)}):Play()
            TweenService:Create(Container, TweenInfo.new(0.3), {Size = UDim2.new(1,-25,0,210)}):Play()
            activeDropdownClose = Toggle
        end
    end
    MainBtn.MouseButton1Click:Connect(Toggle)

    local function RefreshData(newDict)
        optionsDict = newDict
        UpdateNames()
        if DropMain.Visible then Populate(SearchBox.Text) end
    end

    return Container, MainBtn, RefreshData
end

