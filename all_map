local function DisableFollow()
    isFollowing = false
    local followBtn = TeleportPage:FindFirstChild("FollowButtonNode")
    if followBtn then
        followBtn.Text = "auto follow: off"
        followBtn.TextColor3 = Color3.new(1,1,1)
